{
    "name": "whalincode",
    "private": true,
    "version": "1.0.0",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev:cli": "bun run --watch packages/cli/src/index.tsx",
        "dev:server": "bun run --hot packages/server/src/index.ts",
        "format": "prettier . --write",
        "format:check": "prettier . --check"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "bun-types": "^1.3.14",
        "prettier": "^3.9.1",
        "typescript": "^6.0.3"
    }
}
